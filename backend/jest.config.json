{
  "testEnvironment": "node",
  "testTimeout": 30000,
  "collectCoverageFrom": [
    "controllers/**/*.js",
    "middleware/**/*.js",
    "models/**/*.js",
    "services/**/*.js"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 40,
      "functions": 40,
      "lines": 40,
      "statements": 40
    }
  }
}
